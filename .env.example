# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────
# PostgreSQL connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/sales_report_dev?schema=public"

# ──────────────────────────────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────────────────────────────
# Use a long, random string (min 32 chars) — never commit the real value
JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# ──────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000/api/v1"
